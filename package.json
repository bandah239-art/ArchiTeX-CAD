{
  "name": "infraafrica",
  "version": "1.0.0",
  "description": "INFRAFRICA — Calculation Engine + BIM Viewer",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 http://localhost:5174 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "python:install": "pip install -r python/requirements.txt",
    "python:dev": "cd python && uvicorn main:app --reload --port 8000"
  },
  "dependencies": {
    "@xeokit/xeokit-sdk": "^2.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "web-ifc": "^0.0.51",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.infraafrica.app",
    "productName": "INFRAFRICA",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "python/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
