{
  "name": "infraafrica",
  "version": "1.0.0",
  "description": "ARCHITEX-CAD — BIM Viewer + Calculation Engine",
  "main": "electron/main.js",
  "type": "module",
  "workspaces": [
    "packages/*",
    "mobile"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "npm run python:install && concurrently -k \"vite\" \"npm run python:dev\" \"wait-on http://localhost:5173 http-get://127.0.0.1:8000/health && node scripts/start-electron.mjs\"",
    "electron:build": "npm run build && electron-builder",
    "python:install": "py -3 -m pip install -r python/requirements.txt",
    "python:dev": "node scripts/start-python.mjs",
    "python:status": "node -e \"fetch('http://127.0.0.1:8000/health').then(r=>r.json()).then(d=>console.log('Python server OK:',d)).catch(()=>console.log('Python server offline'))\""
  },
  "dependencies": {
    "@infraafrica/shared": "file:packages/shared",
    "@types/leaflet": "^1.9.21",
    "@types/three": "^0.184.1",
    "@xeokit/xeokit-sdk": "^2.6.0",
    "better-sqlite3": "^11.0.0",
    "expo": "56.0.4",
    "i18next": "^26.2.0",
    "leaflet": "^1.9.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.85.3",
    "three": "^0.184.0",
    "web-ifc": "^0.0.68",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^8.0.14",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.architex.cad",
    "productName": "ARCHITEX-CAD",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "python/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
